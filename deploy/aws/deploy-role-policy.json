{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ArtifactBucketReadWrite",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:PutObject"
      ],
      "Resource": "arn:aws:s3:::jira-stats-artifacts-214519213070/*"
    },
    {
      "Sid": "ArtifactBucketRetentionDelete",
      "Effect": "Allow",
      "Action": "s3:DeleteObject",
      "Resource": "arn:aws:s3:::jira-stats-artifacts-214519213070/releases/*"
    },
    {
      "Sid": "ArtifactBucketListForRetention",
      "Effect": "Allow",
      "Action": "s3:ListBucket",
      "Resource": "arn:aws:s3:::jira-stats-artifacts-214519213070",
      "Condition": {
        "StringLike": {
          "s3:prefix": "releases/*"
        }
      }
    },
    {
      "Sid": "SendDeployCommandToTheOneInstance",
      "Effect": "Allow",
      "Action": "ssm:SendCommand",
      "Resource": [
        "arn:aws:ec2:eu-central-1:214519213070:instance/i-0220fc1a6bee863d6",
        "arn:aws:ssm:eu-central-1::document/AWS-RunShellScript"
      ]
    },
    {
      "Sid": "ReadCommandResults",
      "Effect": "Allow",
      "Action": "ssm:GetCommandInvocation",
      "Resource": "*"
    }
  ]
}
