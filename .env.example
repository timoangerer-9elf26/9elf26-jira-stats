# 9elf26-jira-stats configuration.
#
# Copy this file to `.env` and fill in your values. The real `.env` is
# gitignored and must never be committed. Every value below has a safe default
# except the Jira credentials: leave those blank to run against the built-in
# canned fake Jira (handy for local UI work with no live access).

# --- Jira connection (leave all three blank to use the canned fake Jira) ---
# Base URL of your Jira Cloud site.
JIRA_BASE_URL=https://your-site.atlassian.net
# Service-account email for basic auth.
JIRA_EMAIL=service-account@example.com
# Jira API token for the service account (NOT a password). Keep this secret.
JIRA_API_TOKEN=your-api-token

# --- Project / board (used only when live credentials are set) ---
# Project key to sync.
JIRA_PROJECT=DCAI
# Agile board id backing the project.
JIRA_BOARD_ID=8

# --- Runtime settings (all optional; defaults shown) ---
# Timezone for date maths and ISO-week (KW##) labels.
TZ=Europe/Berlin
# Background sync interval (Go duration, e.g. 30s, 60s, 5m).
SYNC_INTERVAL=60s
# Trailing ISO weeks shown on the Velocity view (positive integer).
VELOCITY_WEEKS=10
# Address the HTTP server listens on.
LISTEN_ADDR=:8080
# Path to the SQLite database file (a rebuildable projection of Jira).
DB_PATH=jira-stats.db
